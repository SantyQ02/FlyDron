---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Galeria from '../components/Galeria.astro';
import SobreNosotros from '../components/SobreNosotros.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<BaseLayout title="FlyDron — Aplicaciones Aéreas con Drones | Argentina">
  <Header />
  <main>
    <Hero />
    <Servicios />
    <Galeria />
    <SobreNosotros />
    <Contacto />
  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
