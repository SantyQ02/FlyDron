---
const whatsappUrl = "https://wa.me/5493547641102?text=Hola,%20quiero%20información%20sobre%20los%20servicios%20de%20FlyDron";
---

<!-- Popup overlay -->
<div class="wa-popup" id="whatsapp-popup">
  <div class="wa-popup-card" id="whatsapp-popup-card">
    <button class="wa-popup-close" id="whatsapp-close" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>

    <div class="wa-popup-header">
      <div class="wa-popup-avatar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
      </div>
      <div>
        <span class="wa-popup-name">FlyDron</span>
        <span class="wa-popup-status">En línea</span>
      </div>
    </div>

    <div class="wa-popup-body">
      <div class="wa-popup-bubble">
        <p>Hola! En qué podemos ayudarte?</p>
      </div>
    </div>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-popup-send"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      Enviar mensaje
    </a>
  </div>
</div>

<!-- Float button -->
<button
  class="wa-float"
  id="whatsapp-float-button"
  aria-label="Contactar por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
  </svg>
</button>

<script>
  const floatBtn = document.getElementById('whatsapp-float-button');
  const popup = document.getElementById('whatsapp-popup');
  const popupCard = document.getElementById('whatsapp-popup-card');
  const closeBtn = document.getElementById('whatsapp-close');

  function show() {
    popup?.classList.add('is-open');
  }

  function hide() {
    popup?.classList.remove('is-open');
  }

  floatBtn?.addEventListener('click', show);
  closeBtn?.addEventListener('click', hide);

  // Close on backdrop click
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) hide();
  });

  // Close on scroll
  let scrollTimeout;
  window.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(hide, 100);
  });
</script>

<style>
  /* --- Float Button --- */
  .wa-float {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 9999;
    width: 60px;
    height: 60px;
    background: #25d366;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 4px 14px rgba(37, 211, 102, 0.35),
      0 2px 6px rgba(0, 0, 0, 0.2);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    animation: wa-float 3s ease-in-out infinite;
  }

  .wa-float:hover {
    background: #1ebe5d;
    transform: scale(1.08);
    box-shadow:
      0 6px 20px rgba(37, 211, 102, 0.45),
      0 3px 8px rgba(0, 0, 0, 0.25);
  }

  @keyframes wa-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .wa-float:hover {
    animation: none;
    transform: scale(1.08);
  }

  /* --- Popup --- */
  .wa-popup {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 0 1.5rem 6.5rem;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .wa-popup.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .wa-popup-card {
    width: 340px;
    max-width: calc(100vw - 3rem);
    background: var(--bg-card);
    border: 1px solid var(--gray-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transform: translateY(20px) scale(0.96);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .wa-popup.is-open .wa-popup-card {
    transform: translateY(0) scale(1);
  }

  /* Close button */
  .wa-popup-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.7);
    z-index: 2;
    transition: all var(--transition-fast);
  }

  .wa-popup-close:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  /* Header */
  .wa-popup-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: #25d366;
    color: white;
  }

  .wa-popup-avatar {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wa-popup-name {
    display: block;
    font-family: 'Sora', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .wa-popup-status {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    opacity: 0.85;
  }

  /* Body */
  .wa-popup-body {
    padding: 1.25rem 1.5rem;
  }

  .wa-popup-bubble {
    background: var(--bg-elevated);
    border-radius: 0 var(--radius-md) var(--radius-md) var(--radius-md);
    padding: 0.85rem 1rem;
    display: inline-block;
  }

  .wa-popup-bubble p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.5;
  }

  /* Send button */
  .wa-popup-send {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 1.5rem 1.25rem;
    padding: 0.75rem;
    background: #25d366;
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .wa-popup-send:hover {
    background: #1ebe5d;
  }

  /* --- Responsive --- */
  @media (max-width: 640px) {
    .wa-float {
      right: 1.25rem;
      bottom: 2.5rem;
      width: 72px;
      height: 72px;
    }

    .wa-float svg {
      width: 36px;
      height: 36px;
    }

    .wa-popup {
      padding: 0 1rem 5.5rem;
    }
  }
</style>
