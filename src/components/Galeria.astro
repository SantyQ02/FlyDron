---
import { Image } from 'astro:assets';
import controllerSunset from '../assets/photos/controller-sunset.jpeg';
import droneSpraying from '../assets/photos/drone-spraying-sunset.jpeg';
import fieldSunset from '../assets/photos/field-sunset.jpeg';
import droneGround from '../assets/photos/drone-ground.jpeg';
import fieldWide from '../assets/photos/field-wide.jpeg';
import droneCloseup from '../assets/photos/drone-closeup.jpeg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const photos = [
  { src: controllerSunset, alt: 'Operador controlando drone al atardecer', caption: 'Control de operaciones al atardecer' },
  { src: droneSpraying, alt: 'Drone pulverizando cultivos', caption: 'Pulverización aérea en acción' },
  { src: fieldSunset, alt: 'Vista panorámica del cultivo', caption: 'Vista del cultivo desde la estación de control' },
  { src: droneGround, alt: 'Drone DJI Agras en tierra', caption: 'Drone DJI Agras listo para operar' },
  { src: fieldWide, alt: 'Campo extenso con operación de drone', caption: 'Cobertura de campo a gran escala' },
  { src: droneCloseup, alt: 'Detalle del drone de pulverización', caption: 'Equipamiento de precisión' },
];
---

<section id="galeria" class="section section--dark">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Galería</span>
      <h2 class="section-title">Nuestro Trabajo</h2>
      <p class="section-subtitle">
        Operaciones reales en campos argentinos. Cada imagen refleja
        nuestro compromiso con la excelencia y la precisión.
      </p>
    </div>

    <!-- Photo grid -->
    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <figure class={`gallery-item reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <div class="gallery-image-wrap">
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[350, 500, 700]}
              sizes="(max-width: 600px) 90vw, (max-width: 1024px) 45vw, 30vw"
              class="gallery-img"
            />
            <div class="gallery-caption">
              <span class="gallery-caption-text">{photo.caption}</span>
            </div>
          </div>
        </figure>
      ))}
    </div>

    <!-- Video row -->
    <div class="video-row reveal">
      <div class="video-label">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <polygon points="5,3 13,8 5,13" fill="currentColor"/>
        </svg>
        Videos de operación
      </div>
      <div class="video-carousel-wrapper">
        <button class="video-arrow video-arrow--left" id="video-prev" aria-label="Video anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="video-carousel" id="video-carousel">
          <div class="video-slide">
            <div class="video-wrap">
              <video controls preload="metadata" playsinline>
                <source src={`${base}/videos/operation-2.mp4`} type="video/mp4" />
              </video>
            </div>
          </div>
          <div class="video-slide">
            <div class="video-wrap">
              <video controls preload="metadata" playsinline>
                <source src={`${base}/videos/operation-3.mp4`} type="video/mp4" />
              </video>
            </div>
          </div>
          <div class="video-slide">
            <div class="video-wrap">
              <video controls preload="metadata" playsinline>
                <source src={`${base}/videos/operation-4.mp4`} type="video/mp4" />
              </video>
            </div>
          </div>
        </div>
        <button class="video-arrow video-arrow--right" id="video-next" aria-label="Video siguiente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <div class="video-dots" id="video-dots">
          <span class="video-dot active"></span>
          <span class="video-dot"></span>
          <span class="video-dot"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('video-carousel');
  const prevBtn = document.getElementById('video-prev');
  const nextBtn = document.getElementById('video-next');
  const dots = document.querySelectorAll('.video-dot');
  let current = 0;
  const total = 3;

  const slides = document.querySelectorAll('.video-slide');

  function goTo(index: number) {
    current = Math.max(0, Math.min(index, total - 1));
    if (carousel) {
      carousel.style.transform = `translateX(-${current * 100}%)`;
    }
    dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.visibility = i === current ? 'visible' : 'hidden';
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>

<style>
  /* --- Photo Grid --- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .gallery-item {
    margin: 0;
  }

  .gallery-image-wrap {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--bg-card);
    border: 1px solid var(--gray-border);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-image-wrap:hover {
    border-color: rgba(58, 125, 68, 0.3);
    box-shadow: 0 8px 30px rgba(58, 125, 68, 0.12), 0 0 0 1px rgba(58, 125, 68, 0.1);
    transform: translateY(-4px);
  }

  .gallery-image-wrap :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-image-wrap:hover :global(img) {
    transform: scale(1.04);
  }

  /* Caption overlay */
  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 1rem 0.85rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, transparent 100%);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-image-wrap:hover .gallery-caption {
    transform: translateY(0);
  }

  .gallery-caption-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.01em;
  }

  /* --- Videos --- */
  .video-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Sora', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 1.25rem;
  }

  /* --- Video Carousel --- */
  .video-carousel-wrapper {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
  }

  .video-carousel {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    transition: none;
  }

  .video-slide {
    min-width: 0;
  }

  .video-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--gray-border);
    transition: border-color var(--transition-base);
  }

  .video-wrap:hover {
    border-color: var(--gray-border-hover);
  }

  .video-wrap video {
    width: 100%;
    height: 100%;
    display: block;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: #000;
  }

  /* Arrows — hidden on desktop */
  .video-arrow {
    display: none;
  }

  .video-dots {
    display: none;
  }

  /* --- Responsive --- */
  @media (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    /* Show captions always on mobile */
    .gallery-caption {
      transform: translateY(0);
    }

    /* Carousel mode on mobile */
    .video-carousel-wrapper {
      max-width: 100%;
      overflow: hidden;
    }

    .video-carousel {
      display: flex;
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      gap: 0;
    }

    .video-slide {
      flex: 0 0 100%;
      padding: 0 0.25rem;
      visibility: hidden;
    }

    .video-slide:first-child {
      visibility: visible;
    }

    .video-wrap video {
      aspect-ratio: 9 / 16;
      max-height: 70vh;
    }

    /* Arrows */
    .video-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 50%;
      transform: translateY(-60%);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(10, 10, 10, 0.7);
      border: 1px solid var(--gray-border);
      color: var(--text-primary);
      z-index: 5;
      transition: all var(--transition-fast);
    }

    .video-arrow:active {
      background: rgba(58, 125, 68, 0.2);
      border-color: var(--green-primary);
    }

    .video-arrow--left {
      left: 0.5rem;
    }

    .video-arrow--right {
      right: 0.5rem;
    }

    /* Dots */
    .video-dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .video-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--gray-border-hover);
      transition: all var(--transition-fast);
      cursor: pointer;
    }

    .video-dot.active {
      background: var(--green-mid);
      transform: scale(1.2);
    }
  }
</style>
