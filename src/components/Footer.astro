---
import { Image } from 'astro:assets';
import logoLateral from '../assets/logos/logo-lateral-dark.png';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <Image src={logoLateral} alt="FlyDron" height={40} class="footer-logo" />
        <p class="footer-tagline">
          Tecnología de altura<br />para tu cultivo.
        </p>
      </div>

      <!-- Quick links -->
      <div class="footer-col">
        <span class="footer-col-title">Navegación</span>
        <nav class="footer-links">
          <a href="#inicio">Inicio</a>
          <a href="#servicios">Servicios</a>
          <a href="#galeria">Galería</a>
          <a href="#sobre-nosotros">Sobre Nosotros</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <span class="footer-col-title">Contacto</span>
        <div class="footer-contact">
          <a href="mailto:fflydron@gmail.com">fflydron@gmail.com</a>
          <a href="https://wa.me/5493547641102" target="_blank" rel="noopener noreferrer">3547-641102</a>
          <a href="https://www.instagram.com/_flydron" target="_blank" rel="noopener noreferrer">@_flydron</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; {new Date().getFullYear()} FlyDron — Aplicaciones Aéreas. Todos los derechos reservados.</span>
      <span class="footer-location">Córdoba, Argentina</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-deep);
    border-top: 1px solid var(--gray-border);
    padding: clamp(3rem, 6vw, 5rem) 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand :global(img) {
    height: auto;
    max-height: 45px;
    width: fit-content;
    object-fit: contain;
    align-self: flex-start;
  }

  .footer-tagline {
    font-family: 'Sora', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--text-muted);
  }

  /* Columns */
  .footer-col-title {
    display: block;
    font-family: 'Sora', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-links,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a,
  .footer-contact a {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
    width: fit-content;
  }

  .footer-links a:hover,
  .footer-contact a:hover {
    color: var(--green-mid);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 0;
    border-top: 1px solid var(--gray-border);
  }

  .footer-copy,
  .footer-location {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
