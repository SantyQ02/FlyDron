<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2rem) 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--gray-border);
    border-radius: var(--radius-lg);
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    text-decoration: none;
  }

  .contact-card:hover {
    border-color: var(--gray-border-hover);
    background: var(--bg-card-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  /* Icons */
  .contact-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
  }

  .contact-icon svg {
    width: 24px;
    height: 24px;
  }

  .contact-icon--whatsapp {
    background: rgba(37, 211, 102, 0.1);
    color: #25d366;
    border: 1px solid rgba(37, 211, 102, 0.15);
  }

  .contact-card:hover .contact-icon--whatsapp {
    background: rgba(37, 211, 102, 0.15);
    box-shadow: 0 0 20px rgba(37, 211, 102, 0.15);
  }

  .contact-icon--email {
    background: rgba(58, 125, 68, 0.08);
    color: var(--green-mid);
    border: 1px solid rgba(58, 125, 68, 0.15);
  }

  .contact-card:hover .contact-icon--email {
    background: rgba(58, 125, 68, 0.12);
    box-shadow: 0 0 20px rgba(58, 125, 68, 0.1);
  }

  .contact-icon--instagram {
    background: rgba(225, 48, 108, 0.08);
    color: #e1306c;
    border: 1px solid rgba(225, 48, 108, 0.12);
  }

  .contact-card:hover .contact-icon--instagram {
    background: rgba(225, 48, 108, 0.12);
    box-shadow: 0 0 20px rgba(225, 48, 108, 0.1);
  }

  /* Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .contact-value {
    font-family: 'Sora', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  /* Arrow */
  .contact-arrow {
    color: var(--text-muted);
    transition: all var(--transition-base);
    opacity: 0;
    transform: translateY(4px);
  }

  .contact-card:hover .contact-arrow {
    opacity: 1;
    transform: translateY(0);
    color: var(--text-secondary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .contact-card {
      flex-direction: row;
      text-align: left;
      gap: 1rem;
    }

    .contact-arrow {
      margin-left: auto;
      opacity: 0.5;
      transform: translateY(0);
    }
  }
</style>
